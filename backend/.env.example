# Скопируй в .env и заполни. .env НИКОГДА не коммитится в git.
# Это полный шаблон для боевого/тест-сервера (почта, оплаты, SSL).

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
# ВАЖНО: всегда добавляй 'web' (имя сервиса) — иначе SSR-fetch фронта падает в 400.
# Для домена: cosplayhub.kz,www.cosplayhub.kz,web. Для IP: 109.235.118.28,web
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=cosplayhub
POSTGRES_USER=cosplayhub
POSTGRES_PASSWORD=change-me-too
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Фронт / CSRF / CORS ───────────────────────────────────────────────────────
# Origin ВКЛЮЧАЕТ порт: http://IP и http://IP:8080 — РАЗНЫЕ origin.
# Можно перечислить через запятую в CSRF_TRUSTED_ORIGINS (приоритет над FRONTEND_ORIGIN).
FRONTEND_ORIGIN=https://cosplayhub.kz
CSRF_TRUSTED_ORIGINS=https://cosplayhub.kz,https://www.cosplayhub.kz

# ── SSL / HTTPS (тест ssl) ────────────────────────────────────────────────────
# True ТОЛЬКО когда сайт реально по https (есть сертификат), иначе вход сломается
# (браузер не сохранит Secure-куку по http). Включает Secure-cookie + HSTS.
SECURE_COOKIES=False

# ── Почта (тест почты) ────────────────────────────────────────────────────────
# Тест локально: mailhog (порт 1025, без TLS, ловит письма на :8025).
# Боевая: Brevo — smtp-relay.brevo.com:587, USE_TLS=True, логин/пароль из Brevo.
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-brevo-login
EMAIL_HOST_PASSWORD=your-brevo-smtp-key
DEFAULT_FROM_EMAIL=КосплейХаб <noreply@cosplayhub.kz>

# ── Telegram-бот (OTP по телефону) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ── Оплаты (тест оплат) ───────────────────────────────────────────────────────
# Реальных платежей пока НЕТ — Pro/эскроу/донаты это заглушки до оформления ТОО.
# Kaspi/PayBox ключи появятся здесь после подключения провайдера:
# KASPI_MERCHANT_ID=
# KASPI_API_KEY=
# PAYBOX_MERCHANT_ID=
# PAYBOX_SECRET_KEY=
