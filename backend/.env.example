# Скопируй в .env и заполни. .env НИКОГДА не коммитится в git.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=cosplayhub
POSTGRES_USER=cosplayhub
POSTGRES_PASSWORD=change-me-too
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Фронт (для CORS и cookie)
FRONTEND_ORIGIN=http://localhost:3000
